# =============================================================================
# Opportunity Finder — environment variables
# Copy to .env.local (mobile) / .env (scraper) and fill in. NEVER commit real values.
# Expo: only vars prefixed EXPO_PUBLIC_ are exposed to the mobile client.
# =============================================================================

# --- Convex (mobile client) ---------------------------------------------------
# Written by `npx convex dev` into apps/mobile/.env.local
EXPO_PUBLIC_CONVEX_URL=

# --- Convex (server / scraper only — NEVER expose to the client) --------------
CONVEX_URL=
CONVEX_DEPLOYMENT=
CONVEX_ADMIN_KEY=

# --- Clerk (auth: Google/Apple OAuth, email code, phone OTP) ------------------
# Same publishable key for all methods. Enable Google + Apple OAuth and Email
# code in the Clerk dashboard. For native OAuth redirects, add the app scheme
# `opportunityfinder://` to the allowed redirect origins.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# JWT issuer domain used by convex/auth.config.ts (e.g. https://your-app.clerk.accounts.dev)
CLERK_JWT_ISSUER_DOMAIN=

# --- LLM / embeddings (scraper) -----------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Twilio (WhatsApp reminders + Clerk SMS OTP) ------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Observability ------------------------------------------------------------
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Admin ---------------------------------------------------------------------
# Comma-separated +228 phone numbers allowed to see the hidden admin screen
EXPO_PUBLIC_ADMIN_PHONES=
